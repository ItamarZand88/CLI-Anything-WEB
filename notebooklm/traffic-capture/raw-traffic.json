{
  "meta": {
    "target": "https://notebooklm.google.com/",
    "protocol": "google-batchexecute",
    "base_url": "https://notebooklm.google.com/_/LabsTailwindUi/data/batchexecute",
    "capture_date": "2026-03-15",
    "auth_method": "cookie-based (Google session cookies)",
    "dynamic_params": {
      "at": {"source": "WIZ_global_data.SNlM0e", "description": "CSRF token"},
      "bl": {"source": "WIZ_global_data.cfb2h", "description": "Build label, changes per deploy"},
      "f.sid": {"source": "WIZ_global_data.FdrFJe", "description": "Session ID"},
      "hl": {"description": "UI language code"},
      "source-path": {"description": "Current page path"},
      "_reqid": {"description": "Incrementing request counter"}
    },
    "required_headers": {
      "x-same-domain": "1",
      "content-type": "application/x-www-form-urlencoded;charset=UTF-8",
      "origin": "https://notebooklm.google.com"
    },
    "response_format": ")]}'\\n prefix, then length-prefixed JSON chunks"
  },
  "rpc_methods": {
    "ZwVcOc": {
      "purpose": "Get user settings and quotas",
      "request": "[null,[1,null,null,null,null,null,null,null,null,null,[1]]]",
      "response_summary": "Returns quota limits: [null,[1,100,50,500000],[true],[[1]],[false,1,1,1]]",
      "notes": "100 notebooks, 50 sources per notebook, 500K chars per source"
    },
    "wXbhsf": {
      "purpose": "List all notebooks (owned by user)",
      "request": "[null,1,null,[2]]",
      "response_summary": "Array of notebooks, each: [title, [sources_array], notebook_id, emoji, null, [metadata]]",
      "entity_fields": {
        "title": "string",
        "notebook_id": "UUID string",
        "emoji": "string (icon)",
        "sources": "array of [source_ids[], source_title, [null, word_count, timestamps, source_meta_id, source_type, null, source_subtype], [null, 2]]",
        "source_types": {"3": "PDF upload", "4": "Pasted text", "5": "Web URL", "8": "Pasted text (v2)", "9": "YouTube video", "10": "Audio transcript", "1": "Google Drive doc"},
        "metadata": "[owner_flag, is_shared, is_writable, null, null, [last_modified_timestamp], access_type, is_team, [created_timestamp], ...]"
      }
    },
    "ub2Bae": {
      "purpose": "List shared/team notebooks",
      "request": "[[2]]",
      "response_summary": "Same format as wXbhsf but for shared notebooks"
    },
    "ozz5Z": {
      "purpose": "Get subscription/plan info",
      "request": "[[[null,\"1\",627],[null,null,null,null,null,null,null,null,null,[null,null,1]],1]]",
      "response_summary": "Plan details, upgrade prompts, quota remaining"
    },
    "rLM1Ne": {
      "purpose": "Get notebook details",
      "request_template": "[\"<notebook_id>\",null,[2],null,0]",
      "response_summary": "Same as single notebook from wXbhsf list, with real-time metadata"
    },
    "hPTbtc": {
      "purpose": "Get chat thread IDs for a notebook",
      "request_template": "[[],null,\"<notebook_id>\",20]",
      "response_summary": "Array of thread IDs: [[[thread_id]]]"
    },
    "JFMDGd": {
      "purpose": "Get notebook sharing info and collaborators",
      "request_template": "[\"<notebook_id>\",[2]]",
      "response_summary": "[[[email, permission_level, [], [display_name, avatar_url]]], null, max_collaborators]"
    },
    "sqTeoe": {
      "purpose": "Get studio output templates (audio, video, presentation, text)",
      "request": "[[2,null,null,[1,null,null,null,null,null,null,null,null,null,[1]],[[2,1,3]]],null,1]",
      "response_summary": "Nested arrays of output type definitions with localized labels",
      "output_types": {
        "audio": [
          {"id": 1, "label": "Deep Dive"},
          {"id": 2, "label": "Summary"},
          {"id": 3, "label": "Critique"},
          {"id": 4, "label": "Debate"}
        ],
        "video": [
          {"id": 1, "label": "Explainer Video"},
          {"id": 2, "label": "Summary"}
        ],
        "presentation": [
          {"id": 1, "label": "Detailed Presentation"},
          {"id": 2, "label": "Speaker Slides"}
        ],
        "text": ["Summary", "Study Guide", "Blog Post"]
      }
    },
    "e3bVqc": {
      "purpose": "Get notebook personal notes/annotations",
      "request_template": "[null,null,\"<notebook_id>\"]",
      "response_summary": "Array of notes (can be empty)"
    },
    "gArtLc": {
      "purpose": "List studio artifacts/outputs for a notebook",
      "request_template": "[[2,null,null,[1,null,null,null,null,null,null,null,null,null,[1]],[[2,1,3]]],\"<notebook_id>\",\"NOT artifact.status = \\\"ARTIFACT_STATUS_SUGGESTED\\\"\"]",
      "response_summary": "Array of artifacts with: [artifact_id, title, type, source_refs, status, media_info, timestamps]",
      "artifact_types": {"1": "Audio Overview", "3": "Video", "4": "Quiz", "8": "Presentation"}
    },
    "VfAZjd": {
      "purpose": "Get notebook summary and suggested questions",
      "request_template": "[\"<notebook_id>\",[2]]",
      "response_summary": "[[summary_text], [[suggested_questions_array]], null, null, null, [[question_with_type_array]]], context_id"
    },
    "cFji9": {
      "purpose": "Get chat notes/saved content",
      "request_template": "[\"<notebook_id>\",null,null,[2]]",
      "response_summary": "Array of saved notes with full text content, citations, timestamps, formatting"
    },
    "khqZz": {
      "purpose": "Get chat history (conversation messages)",
      "request_template": "[[],null,null,\"<thread_id>\",20]",
      "response_summary": "Array of message pairs: [message_id, timestamp, role(2=user), null, [[response_text, ...]]]",
      "notes": "Full Q&A with formatted text, citations with source references, bold/code formatting metadata"
    }
  },
  "entities": {
    "notebook": {
      "id_format": "UUID (e.g., cce5d9b4-0446-46d7-9208-1ceb0ceddeea)",
      "url_pattern": "/notebook/<id>",
      "fields": ["title", "emoji", "sources", "metadata", "sharing"]
    },
    "source": {
      "id_format": "UUID",
      "types": ["pasted_text", "pdf_upload", "web_url", "youtube_video", "google_drive_doc", "audio_transcript"],
      "fields": ["id", "title", "word_count", "created_at", "type"]
    },
    "artifact": {
      "id_format": "UUID",
      "types": ["audio_overview", "video", "quiz", "presentation", "text_note"],
      "fields": ["id", "title", "type", "source_refs", "status", "media_urls", "created_at"]
    },
    "chat_thread": {
      "id_format": "UUID",
      "fields": ["id", "messages"]
    },
    "chat_message": {
      "id_format": "UUID",
      "fields": ["id", "timestamp", "role", "text", "citations"]
    }
  },
  "sample_cookies_needed": [
    "SID", "__Secure-1PSID", "__Secure-3PSID",
    "OSID", "__Secure-OSID",
    "HSID", "SSID", "APISID", "SAPISID",
    "__Secure-1PAPISID", "__Secure-3PAPISID",
    "NID", "SIDCC", "__Secure-1PSIDCC", "__Secure-3PSIDCC",
    "__Secure-1PSIDTS", "__Secure-3PSIDTS"
  ]
}
