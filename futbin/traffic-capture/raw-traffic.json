{
  "capture_date": "2026-03-16",
  "target_url": "https://www.futbin.com",
  "app_description": "EA FC 26 Ultimate Team database — player stats, prices, SBCs, market index, evolutions",
  "architecture": "Server-side rendered (Kotlin backend) with HTMX fragments. One JSON API (search), rest is HTML with embedded data.",
  "backend_info": {
    "server": "cloudflare",
    "framework_hint": "x-fb-instance: futbin_kotlin_web_3",
    "version": "x-fb-version: 1.0.569"
  },
  "auth": {
    "type": "cookie-based",
    "cookies_required": ["cf_clearance", "__cflb"],
    "login_required_for": ["comments", "voting", "saved-squads", "my-evolutions"],
    "most_features_public": true
  },
  "endpoints": {
    "json_apis": [
      {
        "method": "GET",
        "url": "/players/search",
        "params": {
          "targetPage": "PLAYER_PAGE",
          "query": "string — player name",
          "year": "26",
          "evolutions": "false"
        },
        "response_type": "application/json",
        "response_schema": {
          "type": "array",
          "items": {
            "id": "number",
            "name": "string",
            "position": "string",
            "version": "string",
            "location": { "url": "string — e.g. /26/player/21610/lionel-messi" },
            "clubImage": "object",
            "nationImage": "object",
            "playerImage": "object",
            "ratingSquare": {
              "rating": "string",
              "color": "string",
              "borderColor": "string",
              "gradient": "string",
              "backgroundColor": "string"
            }
          }
        }
      }
    ],
    "html_pages": [
      {
        "method": "GET",
        "url": "/players",
        "params": {
          "page": "number (1-indexed, 165+ pages)",
          "position": "string — ST, CM, CB, LW, RW, CAM, CDM, LB, RB, GK, etc.",
          "sort": "string — ps_price, pc_price, rating, name, etc.",
          "order": "asc|desc",
          "p_squad": "string — promo filter (FUTBirthday, TOTW26, etc.)",
          "version": "string — card version filter",
          "league": "number — league ID",
          "nation": "number — nation ID",
          "club": "number — club ID"
        },
        "data_extraction": "HTML table with player rows containing: name, rating, position, price, futbin_rating, foot, sm, wf, pac, sho, pas, dri, def, phy, igs, body"
      },
      {
        "method": "GET",
        "url": "/26/player/{id}/{slug}",
        "data_extraction": "Player detail page with embedded JSON data (ratings per chemistry, chemistry styles). Price data in data-recent-prices attributes.",
        "embedded_data": [
          "script[data-futbin-ratings-data-script] — JSON with positionNames, ratingsPerChemistry, ratingsForNoChemistry",
          "script[type=application/json] — chemistry style modifiers",
          "[data-recent-prices] — comma-separated price history"
        ]
      },
      {
        "method": "GET",
        "url": "/26/player/{id}/{slug}/prices",
        "data_extraction": "Price history page with Highcharts data. Graph data in data-ps-data and data-pc-data attributes as [[timestamp,price],...] arrays."
      },
      {
        "method": "GET",
        "url": "/squad-building-challenges",
        "sub_pages": [
          "/squad-building-challenges/cheapest",
          "/squad-building-challenges/squads",
          "/squad-building-challenges/rating-combinations",
          "/squad-building-challenges/best-sbcs",
          "/squad-building-challenges/{category} — Expiring-soon, Players, Upgrades, Challenges, Icons"
        ]
      },
      {
        "method": "GET",
        "url": "/market",
        "sub_pages": [
          "/market/{rating} — 81-86",
          "/market-player-list"
        ]
      },
      {
        "method": "GET",
        "url": "/evolutions",
        "params": {
          "last_chance": "true|false",
          "category": "number"
        },
        "sub_pages": [
          "/evolutions/builder",
          "/evolutions/expired",
          "/players/evolutions",
          "/popular/evolutions"
        ]
      },
      {
        "method": "GET",
        "url": "/popular",
        "description": "Popular players list"
      },
      {
        "method": "GET",
        "url": "/latest",
        "description": "Latest added players"
      }
    ],
    "htmx_fragments": [
      {
        "method": "GET",
        "url": "/26/player/chemistry-link-fragment",
        "params": {
          "playerCardId": "number",
          "linkType": "perfect|strong|weak",
          "page": "number"
        },
        "response_type": "text/html"
      },
      {
        "method": "GET",
        "url": "/26/comments/threads",
        "params": {
          "pageType": "1",
          "pageId": "number — player ID",
          "sorting": "top|new|controversial"
        },
        "response_type": "text/html"
      },
      {
        "method": "GET",
        "url": "/26/player/snapshot-stats/{id}",
        "response_type": "text/html"
      },
      {
        "method": "GET",
        "url": "/26/player/snapshot-prices/{id}",
        "response_type": "text/html"
      },
      {
        "method": "GET",
        "url": "/26/reviews/player/{id}",
        "response_type": "text/html"
      },
      {
        "method": "GET",
        "url": "/market/index-table",
        "response_type": "text/html — table with Name, Last, Change %"
      }
    ]
  },
  "sample_responses": {
    "search_messi": [
      {
        "id": 21610,
        "name": "Lionel Messi",
        "position": "ST",
        "version": "Time Warp",
        "location": { "url": "/26/player/21610/lionel-messi" },
        "ratingSquare": { "rating": "90" }
      },
      {
        "id": 21820,
        "name": "Lionel Messi",
        "position": "ST",
        "version": "TOTY Honourable Ment",
        "location": { "url": "/26/player/21820/lionel-messi" },
        "ratingSquare": { "rating": "90" }
      }
    ],
    "price_graph_sample": {
      "description": "data-ps-data attribute contains [[timestamp_ms, price], ...] arrays",
      "sample": "[[1767312000000,10416000],[1767398400000,7264410],[1767484800000,5961688]]"
    },
    "market_index_table": {
      "description": "HTML table with columns: Name, Last (price), Change %",
      "sample_rows": ["Index 100: 52.83, -6.89%"]
    }
  }
}
